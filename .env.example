# SANASH — Environment Variables
# ================================
# Copy this file to .env and adjust values before running.

# Application
APP_NAME=SANASH API
APP_VERSION=1.0.0
DEBUG=false

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database (PostgreSQL)
DATABASE_URL=postgresql://sanash:sanash@localhost:5432/sanash
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (optional — used by future worker tasks)
REDIS_URL=redis://localhost:6379/0

# Occupancy thresholds
THRESHOLD_YELLOW=0.5
THRESHOLD_RED=0.8

# Alert settings
ALERT_RED_THRESHOLD=0.85
ALERT_COOLDOWN_MINUTES=10

# CORS — React dev server + production origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
